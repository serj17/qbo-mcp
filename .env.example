# qbo-mcp env vars — copy this file to .env and fill in real values.
#
# .env is gitignored; .env.example is the committed template.
# These values are loaded by dotenv at process start when present.

# Sandbox app credentials from https://developer.intuit.com -> your app -> Keys & OAuth -> Development.
# Get production-key values into a separate place (1Password, etc.); do not put them here in dev.
QBO_CLIENT_ID=replace-with-your-sandbox-client-id
QBO_CLIENT_SECRET=replace-with-your-sandbox-client-secret

# Optional. When set, overrides the OS-derived config dir (where tokens.json + qbo-mcp.log live)
# AND bypasses the cloud-sync-folder safety check. Use only if you've intentionally chosen
# a non-default path that's outside any cloud-sync folder.
# QBO_MCP_CONFIG_DIR=

# Optional. One of: debug, info, warn, error. Defaults to info.
# LOG_LEVEL=info
