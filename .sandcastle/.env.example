# Authentication for Claude Code — fill in ONE of the following.
#
# Option A — Anthropic API key (pay-as-you-go):
ANTHROPIC_API_KEY=
#
# Option B — Claude Pro/Max OAuth token (use your subscription):
# Run `claude setup-token` on the host to generate a long-lived token, then
# paste the value here.
# CLAUDE_CODE_OAUTH_TOKEN=
#
# Option C — Persistent OAuth volume (also subscription-based, no token to copy):
# This project's main.mts uses `claudeAuth: true`. Run `claude /login`
# interactively inside the sandbox once via the bootstrap script. Subsequent
# runs reuse those credentials. Leave the keys above blank.
