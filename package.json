{
  "name": "qbo-mcp-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Workspace root for building qbo-mcp via sandcastle. The qbo-mcp package itself is bootstrapped by the AFK agent per .claude/issues/02-skeleton.md.",
  "scripts": {
    "sandcastle:build-image": "sandcastle docker build-image --image-name qbo-mcp-sandcastle:local --dockerfile .sandcastle/Dockerfile",
    "sandcastle:login": "tsx .sandcastle/login.mts",
    "sandcastle": "tsx .sandcastle/main.mts"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "file:./sandcastle",
    "@daytona/sdk": "^0.164.0",
    "tsx": "^4.21.0"
  }
}
